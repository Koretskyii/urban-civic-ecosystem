generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////// ENUMS ////////////////////

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum SystemRole {
  USER
  ADMIN
}

enum CityCreationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportType {
  PROGRESS
  RESOLUTION
  REJECTION
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum InAppNotificationType {
  NEWS_CREATED
  NEWS_UPDATED
  NEWS_DELETED
  ALERT_CREATED
  ALERT_UPDATED
  ALERT_DELETED
  CITY_REQUEST_CREATED
  CITY_REQUEST_ASSIGNED
  CITY_REQUEST_STATUS_UPDATED
  CITY_REQUEST_REPORT_CREATED
  CITY_REQUEST_MESSAGE_CREATED
  SURVEY_CREATED
  SURVEY_CLOSED
}

enum SurveyStatus {
  OPEN
  CLOSED
}

enum ResultsVisibility {
  LIVE
  AFTER_VOTE
  AFTER_CLOSE
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

//////////////////// CITY (TENANT) ////////////////////

model City {
  id        String    @id @default(cuid())
  name      String
  region    String
  centerLat Float?
  centerLng Float?
  deletedAt DateTime?

  users                UserCity[]
  roles                Role[]
  cityRequests         CityRequest[]
  departments          Department[]
  alerts               Alert[]
  alertSubscriptions   AlertSubscription[]   @relation("alertSubscriptions")
  surveys              Survey[]
  news                 GeneralNews[]         @relation("news")
  notifications        InAppNotification[]
  cityCreationRequests CityCreationRequest[]
  attachments          Attachment[]          @relation("cityAttachments")

  cityDomain CityDomain?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt, name])
}

model CityDomain {
  id         String    @id @default(cuid())
  domainName String    @unique
  ownerId    String
  cityId     String    @unique

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

//////////////////// USERS ////////////////////

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String?
  provider     String     @default("local")
  providerId   String?
  systemRole   SystemRole @default(USER)
  isBlocked    Boolean    @default(false)
  blockedAt    DateTime?
  blockedById  String?

  memberships                  UserCity[]
  userRoles                    UserRole[]
  cityRequests                 CityRequest[]
  cityCreationRequests         CityCreationRequest[] @relation("CityCreationRequester")
  reviewedCityCreationRequests CityCreationRequest[] @relation("CityCreationReviewer")
  domainVerifications          DomainVerification[]
  reports                      Report[]
  messages                     Message[]
  alertSubscriptions           AlertSubscription[]
  publishedAlerts              Alert[]               @relation("alertPublisher")
  votes                        Vote[]
  publishedSurveys             Survey[]              @relation("surveyPublisher")
  publishedNews                GeneralNews[]
  notifications                InAppNotification[]
  notificationDeliveries       NotificationDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
}

model UserCity {
  userId String
  cityId String

  joinedAt    DateTime  @default(now())
  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockedById String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@id([userId, cityId])
  @@index([cityId, isBlocked])
}

//////////////////// RBAC ////////////////////

model Role {
  id     String @id @default(cuid())
  name   String
  cityId String

  city  City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  users UserRole[]

  @@unique([cityId, name])
}

model Permission {
  id  String @id @default(cuid())
  key String @unique

  rolePermissions RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])

  @@index([roleId])
}

/// Global role-permission mapping — shared across all cities.
/// roleName matches Role.name (no FK intentionally — roles are fixed constants).
model RolePermission {
  roleName     String
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleName, permissionId])
}

//////////////////// CITY REQUESTS ////////////////////

model CityRequest {
  id                   String        @id @default(cuid())
  cityId               String
  userId               String
  title                String
  description          String?
  status               RequestStatus @default(OPEN)
  locationLat          Float?
  locationLng          Float?
  address              String?
  priority             Int           @default(0)
  assignedDepartmentId String?
  resolvedAt           DateTime?

  city               City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedDepartment Department? @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)

  chat        Chat?
  reports     Report[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cityId, status, createdAt(sort: Desc)])
  @@index([cityId, assignedDepartmentId])
}

model CityCreationRequest {
  id                   String                    @id @default(cuid())
  requesterId          String
  reviewedById         String?
  cityId               String?
  domainVerificationId String?                   @unique
  name                 String
  region               String
  centerLat            Float?
  centerLng            Float?
  domain               String?
  status               CityCreationRequestStatus @default(PENDING)
  rejectionReason      String?
  reviewedAt           DateTime?

  requester          User                @relation("CityCreationRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewedBy         User?               @relation("CityCreationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  city               City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  domainVerification DomainVerification? @relation(fields: [domainVerificationId], references: [id], onDelete: SetNull)

  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([requesterId, status])
  @@index([cityId])
  @@index([reviewedById])
  @@index([name, region])
}

model DomainVerification {
  id          String    @id @default(cuid())
  requesterId String
  domain      String
  token       String    @unique
  verifiedAt  DateTime?

  requester           User                 @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  cityCreationRequest CityCreationRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId, domain, verifiedAt])
  @@index([domain, verifiedAt])
}

model Department {
  id          String  @id @default(cuid())
  cityId      String
  name        String
  type        String
  description String?
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false)

  city         City          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  cityRequests CityRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, name])
  @@index([cityId, isActive])
}

model Report {
  id          String         @id @default(cuid())
  description String?
  authorId    String
  type        ReportType
  status      RequestStatus?

  cityRequestId String
  cityRequest   CityRequest @relation(fields: [cityRequestId], references: [id], onDelete: Cascade)
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cityRequestId])
  @@index([authorId])
}

model Attachment {
  id         String  @id @default(cuid())
  fileName   String
  mimeType   String?
  url        String
  type       String?

  reportId String?
  report   Report? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  cityRequestId String?
  cityRequest   CityRequest? @relation(fields: [cityRequestId], references: [id], onDelete: Cascade)

  cityCreationRequestId String?
  cityCreationRequest   CityCreationRequest? @relation(fields: [cityCreationRequestId], references: [id], onDelete: Cascade)

  newsId String?
  news   GeneralNews? @relation(fields: [newsId], references: [id], onDelete: Cascade)

  cityId String?
  city   City?   @relation("cityAttachments", fields: [cityId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())

  @@index([cityRequestId])
  @@index([reportId])
  @@index([cityCreationRequestId])
  @@index([newsId])
  @@index([cityId])
}

//////////////////// CHAT ////////////////////

model Chat {
  id            String @id @default(cuid())
  cityRequestId String @unique

  cityRequest CityRequest @relation(fields: [cityRequestId], references: [id], onDelete: Cascade)
  messages    Message[]

  createdAt DateTime @default(now())
}

model Message {
  id       String @id @default(cuid())
  chatId   String
  authorId String
  content  String

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@index([chatId, timestamp])
  @@index([authorId])
}

//////////////////// ALERTS ////////////////////

model Alert {
  id          String        @id @default(cuid())
  cityId      String
  publisherId String?
  alertTypeId String
  severity    AlertSeverity @default(MEDIUM)
  expiresAt   DateTime?
  title       String
  content     String

  city      City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  publisher User?     @relation("alertPublisher", fields: [publisherId], references: [id], onDelete: Cascade)
  alertType AlertType @relation(fields: [alertTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cityId, deletedAt, severity, createdAt(sort: Desc)])
  @@index([cityId, alertTypeId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@index([publisherId])
}

model AlertType {
  id   String @id @default(cuid())
  name String @unique

  alerts        Alert[]
  subscriptions AlertSubscription[]
}

model AlertSubscription {
  userId      String
  cityId      String
  alertTypeId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  city      City      @relation("alertSubscriptions", fields: [cityId], references: [id], onDelete: Cascade)
  alertType AlertType @relation(fields: [alertTypeId], references: [id], onDelete: Cascade)

  @@id([userId, cityId, alertTypeId])
}

//////////////////// SURVEYS ////////////////////

model Survey {
  id                String            @id @default(cuid())
  cityId            String
  publisherId       String?
  title             String
  description       String?
  status            SurveyStatus      @default(OPEN)
  resultsVisibility ResultsVisibility @default(AFTER_CLOSE)
  allowVoteChange   Boolean           @default(true)
  closesAt          DateTime?
  closedAt          DateTime?

  city      City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  publisher User?          @relation("surveyPublisher", fields: [publisherId], references: [id], onDelete: SetNull)
  options   SurveyOption[]
  votes     Vote[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cityId, status, deletedAt, createdAt(sort: Desc)])
  @@index([status, closesAt])
  @@index([publisherId])
}

model SurveyOption {
  id       String @id @default(cuid())
  surveyId String
  text     String
  position Int    @default(0)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  votes  Vote[]

  @@index([surveyId, position])
}

model Vote {
  id             String @id @default(cuid())
  surveyId       String
  surveyOptionId String
  userId         String

  survey    Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  option    SurveyOption @relation(fields: [surveyOptionId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([surveyId, userId])
  @@index([surveyOptionId])
}

//////////////////// GENERAL NEWS ////////////////////

model GeneralNews {
  id          String   @id @default(cuid())
  cityId      String
  publisherId String
  title       String
  content     String

  attachments Attachment[]
  city        City         @relation("news", fields: [cityId], references: [id], onDelete: Cascade)
  publisher   User         @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cityId, deletedAt, createdAt(sort: Desc)])
  @@index([publisherId])
}

//////////////////// OUTBOX ////////////////////

model DomainEventOutbox {
  id            String       @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now())
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  notificationDeliveries NotificationDelivery[]

  @@index([status, availableAt, createdAt])
  @@index([aggregateType, aggregateId])
}

model InAppNotification {
  id        String                @id @default(cuid())
  userId    String
  cityId    String
  type      InAppNotificationType
  eventId   String?
  title     String
  body      String?
  link      String?
  payload   Json?
  isRead    Boolean               @default(false)
  readAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([cityId, createdAt(sort: Desc)])
  @@unique([userId, eventId, type])
}

model NotificationDelivery {
  id            String    @id @default(cuid())
  outboxEventId String
  userId        String
  channel       String
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  recipient     String
  subject       String
  lastError     String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  outboxEvent DomainEventOutbox @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([outboxEventId, userId, channel])
  @@index([status, createdAt])
  @@index([userId, channel, createdAt(sort: Desc)])
}
